# Copie para .env e preencha. Não commite .env.

# Google Sheets (RSVP / presentes / admin)
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Opcional: após cada RSVP bem-sucedido, a API chama EmailJS (servidor).
# Template: {{name}} e {{email}}.
# Security (API fora do browser): https://dashboard.emailjs.com/admin/account/security
# API keys (Public + Private): https://dashboard.emailjs.com/admin/account
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
